+     */
+    public void createFragments(Predicate<String> isMethodHotPredicate) throws ExperimentParserError {
+        List<CompilationUnit> compilationUnitsSnapshot = new ArrayList<>();
+        for (CompilationUnit unit : getHotCompilationUnits()) {
+            if (!(unit instanceof CompilationFragment)) {
+                compilationUnitsSnapshot.add(unit);
+            }
+        }
+
+        for (CompilationUnit compilationUnit : compilationUnitsSnapshot) {
+            compilationUnit.loadTrees().getInliningTree().getRoot().forEach(node -> {
+                if (node.getParent() != null
+                        && node.isPositive()
+                        && node.getName() != null
+                        && isMethodHotPredicate.test(node.getName())) {
+                    Method inlineeMethod = experiment.getMethodOrCreate(node.getName());
+                    inlineeMethod.addCompilationFragment(compilationUnit, node);
+                }
+            });
+        }
+    }
