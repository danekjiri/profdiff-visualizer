{
  "name": "profdiff-web-application",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "generate-api": "cross-env TS_POST_PROCESS_FILE=\"npx prettier --write\" openapi-generator-cli generate -g typescript-angular -i ../../backend/profdiff-api/target/classes/META-INF/swagger/profdiff-web-app-api-0.0.yml -o src/app/ --additional-properties=modelPackage=models/dto,ngVersion=20.0 --global-property=models,apis=false,supportingFiles=false --enable-post-process-file",
    "docs": "compodoc -p tsconfig.doc.json -s"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.1.0",
    "@angular/common": "^20.3.6",
    "@angular/compiler": "^20.3.6",
    "@angular/core": "^20.3.6",
    "@angular/forms": "^20.3.6",
    "@angular/material": "^20.1.0",
    "@angular/platform-browser": "^20.3.6",
    "@angular/platform-browser-dynamic": "^20.3.6",
    "@angular/router": "^20.3.6",
    "@swimlane/ngx-charts": "^23.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-builders/jest": "^20.0.0",
    "@angular-devkit/build-angular": "^20.3.6",
    "@angular/cli": "^20.3.6",
    "@angular/compiler-cli": "^20.3.6",
    "@compodoc/compodoc": "^1.2.1",
    "@openapitools/openapi-generator-cli": "^2.25.2",
    "@types/jest": "^29.5.14",
    "baseline-browser-mapping": "^2.9.15",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-preset-angular": "^14.6.2",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3"
  }
}
